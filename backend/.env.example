# Copy to .env and fill in. Never commit real tokens.

# Required for live Instagram and TikTok crawling
APIFY_TOKEN=

# Optional override (default: datadoping~instagram-followers-scraper)
# APIFY_INSTAGRAM_ACTOR=datadoping~instagram-followers-scraper

# Optional TikTok actor overrides
# APIFY_TIKTOK_FOLLOWERS_ACTOR=coregent~tiktok-followers-following-scraper
# APIFY_TIKTOK_POSTS_ACTOR=clockworks~tiktok-scraper

# Local (free) background scraper — no Apify, no login needed. Reads public
# og:meta via a link-preview user-agent. Keep the delay polite and cap modest.
# WORMBLAZZ_LOCAL_DELAY=1.5
# WORMBLAZZ_LOCAL_MAX_NODES=120

# OPTIONAL: only if you want the richer Instagram JSON (related profiles, captions).
# Public profiles already work without this. Paste your own browser sessionid.
# INSTAGRAM_SESSION_ID=
# INSTAGRAM_COOKIES=sessionid=...; csrftoken=...

# WORMBLAZZ_CACHE_DIR=.cache
# WORMBLAZZ_CORS_ORIGINS=http://localhost:5173
